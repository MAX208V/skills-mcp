{
  "functions": {
    "api/mcp.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "headers": [
    {
      "source": "/api/mcp",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Accept,Mcp-Session-Id" }
      ]
    }
  ]
}
